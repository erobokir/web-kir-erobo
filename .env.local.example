# Salin file ini menjadi ".env.local" di root project (bukan di folder backend)

# URL backend Express untuk sistem inventaris (lihat folder /backend)
NEXT_PUBLIC_INVENTORY_API_URL=http://localhost:4000

# --- Modul Website Hosting (Supabase Auth + Storage) ---
# Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=isi-dengan-anon-public-key
# PENTING: service_role key HARUS dirahasiakan, jangan pernah diberi prefix NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=isi-dengan-service-role-key

# --- Modul Diklat (spreadsheet real-time) ---
# String acak & rahasia untuk menandatangani cookie sesi role "diklat".
DIKLAT_SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

